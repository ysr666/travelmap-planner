VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_ROUTE_PROXY_URL=
VITE_ROUTE_PROXY_PROVIDER=openrouteservice

# Browser-visible Google Maps JavaScript key for map rendering, Places, and Routes.
# Provider proxy also reuses this first for Google Places / Routes when present.
# Restrict this key by HTTP referrer in Google Cloud.
VITE_GOOGLE_MAPS_API_KEY=

# Route Provider Proxy (server-side only, never expose through VITE_*)
# OPENROUTESERVICE_API_KEY=
# GOOGLE_ROUTES_API_KEY=
# Optional shared server-side Google Maps Platform key fallback for Routes and Places.
# Used only when VITE_GOOGLE_MAPS_API_KEY is absent.
# GOOGLE_MAPS_PLATFORM_API_KEY=

# AI Draft Provider (server-side only, never commit real keys)
# TRIPMAP_AI_PROVIDER=disabled | mock | openai_compatible
# TRIPMAP_AI_API_KEY=
# TRIPMAP_AI_BASE_URL=https://api.example.com/v1
# TRIPMAP_AI_MODEL=gpt-4o-mini

# Travel Search Provider (server-side only, never commit real keys)
# TRIPMAP_SEARCH_PROVIDER=disabled | mock | tavily
# TRIPMAP_SEARCH_API_KEY=

# Google Places Lookup Provider (server-side only, never commit real keys)
# TRIPMAP_PLACE_PROVIDER=disabled | mock | google_places
# Defaults to google_places when a Google key is present; set disabled to force it off.
# TRIPMAP_GOOGLE_PLACES_API_KEY=
# Used only when VITE_GOOGLE_MAPS_API_KEY and GOOGLE_MAPS_PLATFORM_API_KEY are absent.

# Provider Quota (Cloudflare D1 binding, not a string env var)
# Bind the D1 database as TRIPMAP_PROVIDER_QUOTA_D1 in Pages/Workers.
# TRIPMAP_PROVIDER_PROXY_ENV=development | preview | production
# TRIPMAP_PROVIDER_PROXY_REQUIRE_AUTH=1
# TRIPMAP_PROVIDER_PROXY_ALLOWED_ORIGINS=https://travelmap-planner.pages.dev
# TRIPMAP_PROVIDER_PROXY_KILL_SWITCH=global | ai,search,place,route,fx
# Optional server-side aliases; runtime falls back to the matching VITE_* Supabase public config.
# TRIPMAP_SUPABASE_URL=
# TRIPMAP_SUPABASE_ANON_KEY=
# Optional free Email Service binding after ysr182@qq.com is a verified destination.
# Bind as TRIPMAP_PROVIDER_ALERT_EMAIL and set a verified routing-domain sender.
# TRIPMAP_PROVIDER_ALERT_FROM=
